# Spoo.me API Configuration (Official API)
# Get your API key from https://spoo.me/dashboard → Settings → API Keys
# API key format: spoo_xxxxxxxxxxxxx
# Optional but recommended for higher rate limits (60/min vs 20/min)
VITE_SPOO_ME_API_KEY=spoo_your_api_key_here

# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# API Endpoints (Hardcoded - no need to configure):
# - Regular URLs: https://spoo.me/api/v1/shorten (v1 API)
# - Emoji URLs: https://spoo.me/emoji (v0 API)
# - Analytics: https://spoo.me/stats/{shortcode} (v0 API)
